{
  "name": "@eidra/tokens",
  "version": "1.6.0",
  "description": "Eidra design tokens — colors, type, spacing, themes.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/eidra-tokens.css",
    "./tailwind": "./dist/tailwind-preset.cjs",
    "./tailwind.css": "./dist/tailwind.css",
    "./tailwind-reset.css": "./dist/tailwind-reset.css",
    "./fonts.css": "./dist/fonts.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs && vite build",
    "dev": "node build.mjs && vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "style-dictionary": "^5.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
