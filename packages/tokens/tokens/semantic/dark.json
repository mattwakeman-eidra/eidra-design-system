{
  "bg": {
    "DEFAULT": { "$type": "color", "$value": "{color.grey.950}" },
    "subtle":  { "$type": "color", "$value": "{color.grey.1000}" },
    "muted":   { "$type": "color", "$value": "{color.grey.800}" },
