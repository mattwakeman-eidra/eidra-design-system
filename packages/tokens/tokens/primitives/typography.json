{
  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Eidra Sans", "Inter", "Helvetica Neue", "Arial", "system-ui", "sans-serif"]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["Eidra Sans Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
      }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "xs":      { "$type": "dimension", "$value": "0.75rem" },
      "sm":      { "$type": "dimension", "$value": "0.875rem" },
      "base":    { "$type": "dimension", "$value": "1rem" },
      "md":      { "$type": "dimension", "$value": "1.125rem" },
      "lg":      { "$type": "dimension", "$value": "1.25rem" },
      "xl":      { "$type": "dimension", "$value": "1.5rem" },
      "2xl":     { "$type": "dimension", "$value": "1.875rem" },
      "3xl":     { "$type": "dimension", "$value": "2.25rem" },
      "4xl":     { "$type": "dimension", "$value": "3rem" },
      "5xl":     { "$type": "dimension", "$value": "3.75rem" },
      "6xl":     { "$type": "dimension", "$value": "5.625rem" },
      "display": { "$type": "dimension", "$value": "8.5rem" }
    },
    "line-height": {
      "none":    { "$type": "number", "$value": 1 },
      "tight":   { "$type": "number", "$value": 1.1 },
      "snug":    { "$type": "number", "$value": 1.25 },
      "normal":  { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.6 }
    },
    "letter-spacing": {
      "display": { "$type": "dimension", "$value": "-0.02em" },
      "tight":   { "$type": "dimension", "$value": "-0.01em" },
      "normal":  { "$type": "dimension", "$value": "0em" },
      "wide":    { "$type": "dimension", "$value": "0.02em" }
    }
  }
}
