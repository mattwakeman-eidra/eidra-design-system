{
  "shadow": {
    "xs": { "$type": "shadow", "$value": "0 1px 2px rgba(15, 15, 15, 0.06)" },
    "sm": {
      "$type": "shadow",
      "$value": "0 1px 3px rgba(15, 15, 15, 0.08), 0 1px 2px rgba(15, 15, 15, 0.06)"
    },
    "md": {
      "$type": "shadow",
      "$value": "0 4px 8px rgba(15, 15, 15, 0.08), 0 2px 4px rgba(15, 15, 15, 0.06)"
    },
    "lg": {
      "$type": "shadow",
      "$value": "0 12px 24px rgba(15, 15, 15, 0.10), 0 4px 8px rgba(15, 15, 15, 0.06)"
    },
    "xl": {
      "$type": "shadow",
      "$value": "0 24px 48px rgba(15, 15, 15, 0.14), 0 8px 16px rgba(15, 15, 15, 0.08)"
    }
  },
  "duration": {
    "instant": { "$type": "duration", "$value": "80ms" },
    "fast": { "$type": "duration", "$value": "120ms" },
    "base": { "$type": "duration", "$value": "200ms" },
    "slow": { "$type": "duration", "$value": "320ms" }
  },
  "easing": {
    "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
    "emphasized": { "$type": "cubicBezier", "$value": [0.3, 0, 0, 1] },
    "decelerate": { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
    "accelerate": { "$type": "cubicBezier", "$value": [0.3, 0, 1, 1] }
  },
  "z": {
    "base": { "$type": "number", "$value": 0 },
    "raised": { "$type": "number", "$value": 10 },
    "dropdown": { "$type": "number", "$value": 1000 },
    "sticky": { "$type": "number", "$value": 1100 },
    "overlay": { "$type": "number", "$value": 1300 },
    "modal": { "$type": "number", "$value": 1400 },
    "popover": { "$type": "number", "$value": 1500 },
    "toast": { "$type": "number", "$value": 1700 },
    "tooltip": { "$type": "number", "$value": 1800 }
  }
}
