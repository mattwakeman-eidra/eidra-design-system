{
  "name": "@eidra/react",
  "version": "1.6.0",
  "description": "Eidra React component library, built on Base UI.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./tailwind.css": "./dist/tailwind.css",
    "./tailwind-reset.css": "./dist/tailwind-reset.css"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "vite build && node scripts/add-use-client.mjs && node scripts/copy-tailwind.mjs && node scripts/wrap-css-layer.mjs && node scripts/check-build.mjs",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'test/**/*.test.mjs'"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@eidra/icons": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "clsx": "^2.1.1",
    "recharts": "^3.7.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eidra/icons": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
