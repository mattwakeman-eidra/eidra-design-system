{
  "name": "@eidra/react",
  "version": "1.0.0",
  "description": "Eidra React component library, built on Base UI.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "vite build && node scripts/add-use-client.mjs && node scripts/check-build.mjs",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "@eidra/icons": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eidra/icons": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^5.0.2"
  }
}
