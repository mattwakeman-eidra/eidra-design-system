{
  "name": "eidra-design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter @eidra/tokens build && pnpm --filter @eidra/icons build && pnpm --filter @eidra/react build",
    "build:tokens": "pnpm --filter @eidra/tokens build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint . && stylelint \"packages/**/src/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"packages/**/src/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project=storybook",
    "test-storybook:watch": "vitest --project=storybook",
    "coverage": "vitest run --project=storybook --coverage && (open coverage/index.html 2>/dev/null || true)",
    "catalog": "node scripts/catalog.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/release.mjs",
    "release:github": "node scripts/release.mjs && node scripts/github-release.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eidra/icons": "workspace:*",
    "@eidra/react": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@mdx-js/mdx": "^3.1.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mermaid": "^11.16.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.6",
    "stylelint": "^17.14.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
