{
  "name": "eidra-design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @eidra/tokens build && pnpm --filter @eidra/icons build && pnpm --filter @eidra/react build",
    "build:tokens": "pnpm --filter @eidra/tokens build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint . && stylelint \"packages/**/src/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"packages/**/src/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project=storybook",
    "test-storybook:watch": "vitest --project=storybook",
    "coverage": "vitest run --project=storybook --coverage && (open coverage/index.html 2>/dev/null || true)",
    "catalog": "node scripts/catalog.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/release.mjs",
    "release:github": "node scripts/release.mjs && node scripts/github-release.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eidra/icons": "workspace:*",
    "@eidra/react": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.6.0",
    "playwright": "^1.50.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "stylelint": "^17.13.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
