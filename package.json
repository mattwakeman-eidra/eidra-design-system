{
  "name": "eidra-design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @eidra/tokens build && pnpm --filter @eidra/icons build && pnpm --filter @eidra/react build",
    "build:tokens": "pnpm --filter @eidra/tokens build",
    "typecheck": "pnpm -r --parallel typecheck",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "catalog": "node scripts/catalog.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node scripts/release.mjs",
    "release:github": "node scripts/release.mjs && node scripts/github-release.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eidra/icons": "workspace:*",
    "@eidra/react": "workspace:*",
    "@eidra/tokens": "workspace:*",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
